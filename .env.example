# Example environment variables for AI Job Application Assistant
# Copy to a file named .env and fill with real API keys / settings.

# Web search API (SerpAPI / Bing)
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=

# LLM / Provider keys
OPENAI_API_KEY=
GOOGLE_GENAI_API_KEY=

# Optional runtime settings
STREAMLIT_SERVER_PORT=8501
LOG_LEVEL=INFO

# LangChain or other service keys
LANGCHAIN_API_KEY=
